import React, { useState, useEffect, useCallback, useRef } from 'react';
import {
  View,
  Text,
  ScrollView,
  StyleSheet,
  RefreshControl,
  Pressable,
  Animated,
  TextInput,
  Platform,
} from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { useRouter } from 'expo-router';
import { useSafeAreaInsets } from 'react-native-safe-area-context';
import { MaterialCommunityIcons } from '@expo/vector-icons';
import { useTheme } from '../../store/theme';
import { useFavoritesStore } from '../../store/favorites';
import { FeatureCard } from '../../components/ui/FeatureCard';
import { searchFeatures, categories, getFeatureById } from '../../constants/features';
import { CATEGORY_COLORS } from '../../constants/theme';
import { fetchWeather, fetchQuote } from '../../lib/api';
import { lightImpact } from '../../lib/haptics';

// ─── Greeting ────────────────────────────────────────────────────────────────

function getGreeting() {
  const h = new Date().getHours();
  if (h < 12) return 'Good morning ☀️';
  if (h < 17) return 'Good afternoon 🌤';
  if (h < 21) return 'Good evening 🌆';
  return 'Good night 🌙';
}

// ─── Weather icon helper ──────────────────────────────────────────────────────

const WEATHER_ICONS: Record<number, { icon: string; label: string }> = {
  0:  { icon: 'weather-sunny',         label: 'Clear' },
  1:  { icon: 'weather-partly-cloudy', label: 'Mainly clear' },
  2:  { icon: 'weather-partly-cloudy', label: 'Partly cloudy' },
  3:  { icon: 'weather-cloudy',        label: 'Overcast' },
  45: { icon: 'weather-fog',           label: 'Foggy' },
  51: { icon: 'weather-rainy',         label: 'Drizzle' },
  61: { icon: 'weather-rainy',         label: 'Rain' },
  71: { icon: 'weather-snowy',         label: 'Snow' },
  95: { icon: 'weather-lightning',     label: 'Thunderstorm' },
};

function getWeatherInfo(code: number) {
  return WEATHER_ICONS[code] ?? { icon: 'weather-partly-cloudy', label: 'Weather' };
}

// ─── Section Header ───────────────────────────────────────────────────────────

function SectionHeader({ title, action, onAction }: { title: string; action?: string; onAction?: () => void }) {
  const { theme } = useTheme();
  return (
    <View style={sectionHeaderStyles.row}>
      <View style={[sectionHeaderStyles.bar, { backgroundColor: theme.colors.accent }]} />
      <Text style={[sectionHeaderStyles.title, { color: theme.colors.text, fontFamily: theme.fontFamily.bold }]}>
        {title}
      </Text>
      {action && (
        <Pressable onPress={onAction}>
          <Text style={[sectionHeaderStyles.action, { color: theme.colors.accent, fontFamily: theme.fontFamily.medium }]}>
            {action}
          </Text>
        </Pressable>
      )}
    </View>
  );
}
const sectionHeaderStyles = StyleSheet.create({
  row:    { flexDirection: 'row', alignItems: 'center', marginBottom: 12, gap: 10 },
  bar:    { width: 4, height: 18, borderRadius: 2 },
  title:  { flex: 1, fontSize: 17 },
  action: { fontSize: 13 },
});

// ─── Main Screen ─────────────────────────────────────────────────────────────

export default function DailyScreen() {
  const { theme, isDark } = useTheme();
  const insets  = useSafeAreaInsets();
  const router  = useRouter();
  const { pinnedFeatures, recentFeatures, addRecent, togglePin } = useFavoritesStore();

  const [search, setSearch]       = useState('');
  const [refreshing, setRefreshing] = useState(false);
  const [weather, setWeather]     = useState<any>(null);
  const [quote, setQuote]         = useState<{ content: string; author: string } | null>(null);
  const [loading, setLoading]     = useState(true);

  const searchFocused = useRef(false);
  const headerOpacity = useRef(new Animated.Value(1)).current;

  const loadData = useCallback(async () => {
    try {
      const [w, q] = await Promise.allSettled([fetchWeather(40.71, -74.01), fetchQuote()]);
      if (w.status === 'fulfilled') setWeather(w.value);
      if (q.status === 'fulfilled') setQuote(q.value);
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => { loadData(); }, [loadData]);

  const onRefresh = async () => {
    setRefreshing(true);
    await loadData();
    setRefreshing(false);
  };

  const navigate = (route: string, id: string) => {
    addRecent(id);
    router.push(route as any);
  };

  const filteredFeatures = search.trim() ? searchFeatures(search) : null;
  const pinnedItems  = pinnedFeatures.map(getFeatureById).filter(Boolean);
  const recentItems  = recentFeatures.slice(0, 8).map(getFeatureById).filter(Boolean);

  const weatherInfo = weather ? getWeatherInfo(weather.current?.weathercode ?? 0) : null;
  const temp        = weather ? Math.round(weather.current?.temperature_2m ?? 0) : null;
  const wind        = weather?.current?.wind_speed_10m ?? 0;

  // Category tiles config
  const categoryTiles = [
    { id: 'tools',     label: 'Tools',     icon: 'toolbox',      route: '/(tabs)/tools',     cat: 'tools'     as const },
    { id: 'finance',   label: 'Finance',   icon: 'chart-line',   route: '/(tabs)/finance',   cat: 'finance'   as const },
    { id: 'wellness',  label: 'Wellness',  icon: 'heart-pulse',  route: '/(tabs)/wellness',  cat: 'wellness'  as const },
    { id: 'utilities', label: 'More',      icon: 'apps',         route: '/(tabs)/utilities', cat: 'utilities' as const },
  ];

  return (
    <View style={[styles.root, { backgroundColor: theme.colors.background }]}>
      <ScrollView
        showsVerticalScrollIndicator={false}
        refreshControl={<RefreshControl refreshing={refreshing} onRefresh={onRefresh} tintColor={theme.colors.accent} />}
        stickyHeaderIndices={[]}
      >
        {/* ── Gradient Header ── */}
        <LinearGradient
          colors={[...theme.colors.gradient]}
          start={{ x: 0, y: 0 }}
          end={{ x: 1, y: 1 }}
          style={[styles.header, { paddingTop: insets.top + 16 }]}
        >
          {/* Logo row */}
          <View style={styles.headerTop}>
            <View style={styles.logoRow}>
              <View style={styles.logoIcon}>
                <MaterialCommunityIcons name="lightning-bolt" size={20} color="#FFFFFF" />
              </View>
              <Text style={styles.logoText}>PockIt</Text>
            </View>
            <Pressable
              onPress={() => { lightImpact(); router.push('/settings' as any); }}
              style={styles.settingsBtn}
            >
              <MaterialCommunityIcons name="cog-outline" size={22} color="rgba(255,255,255,0.85)" />
            </Pressable>
          </View>

          {/* Greeting */}
          <Text style={styles.greeting}>{getGreeting()}</Text>
          <Text style={styles.subGreeting}>What would you like to do?</Text>

          {/* Search bar */}
          <View style={[styles.searchBar, { backgroundColor: isDark ? 'rgba(255,255,255,0.12)' : 'rgba(255,255,255,0.9)' }]}>
            <MaterialCommunityIcons name="magnify" size={20} color={isDark ? 'rgba(255,255,255,0.6)' : '#8888AA'} />
            <TextInput
              style={[styles.searchInput, { color: isDark ? '#FFFFFF' : theme.colors.text }]}
              placeholder="Search 40+ features..."
              placeholderTextColor={isDark ? 'rgba(255,255,255,0.5)' : '#9090AA'}
              value={search}
              onChangeText={setSearch}
              returnKeyType="search"
            />
            {search.length > 0 && (
              <Pressable onPress={() => setSearch('')}>
                <MaterialCommunityIcons name="close-circle" size={18} color={isDark ? 'rgba(255,255,255,0.5)' : '#9090AA'} />
              </Pressable>
            )}
          </View>
        </LinearGradient>

        <View style={styles.body}>
          {/* ── Search Results ── */}
          {filteredFeatures ? (
            <View>
              <SectionHeader title={`Results for "${search}"`} />
              {filteredFeatures.length === 0 ? (
                <View style={styles.emptySearch}>
                  <MaterialCommunityIcons name="magnify-close" size={48} color={theme.colors.textTertiary} />
                  <Text style={[styles.emptyText, { color: theme.colors.textSecondary }]}>No features found</Text>
                </View>
              ) : (
                <View style={styles.grid}>
                  {filteredFeatures.map((f) => (
                    <View key={f.id} style={styles.gridItem}>
                      <FeatureCard
                        icon={f.icon}
                        title={f.name}
                        description={f.description}
                        category={f.category as any}
                        onPress={() => navigate(f.route, f.id)}
                        onLongPress={() => togglePin(f.id)}
                        isPinned={pinnedFeatures.includes(f.id)}
                      />
                    </View>
                  ))}
                </View>
              )}
            </View>
          ) : (
            <>
              {/* ── Category Quick Access ── */}
              <View style={styles.catRow}>
                {categoryTiles.map((cat) => {
                  const colors = isDark ? CATEGORY_COLORS[cat.cat].dark : CATEGORY_COLORS[cat.cat].light;
                  return (
                    <Pressable
                      key={cat.id}
                      style={[styles.catTile, { backgroundColor: colors.bg, borderColor: colors.icon + '33' }]}
                      onPress={() => { lightImpact(); router.push(cat.route as any); }}
                    >
                      <MaterialCommunityIcons name={cat.icon as any} size={22} color={colors.icon} />
                      <Text style={[styles.catLabel, { color: colors.icon, fontFamily: theme.fontFamily.semiBold }]}>
                        {cat.label}
                      </Text>
                    </Pressable>
                  );
                })}
              </View>

              {/* ── Pinned ── */}
              {pinnedItems.length > 0 && (
                <View style={styles.section}>
                  <SectionHeader title="Pinned" />
                  <ScrollView horizontal showsHorizontalScrollIndicator={false} contentContainerStyle={{ gap: 10 }}>
                    {pinnedItems.map((f) => (
                      <FeatureCard
                        key={f!.id}
                        icon={f!.icon}
                        title={f!.name}
                        size="small"
                        isPinned
                        category={f!.category as any}
                        onPress={() => navigate(f!.route, f!.id)}
                        onLongPress={() => togglePin(f!.id)}
                      />
                    ))}
                  </ScrollView>
                </View>
              )}

              {/* ── Recent ── */}
              {recentItems.length > 0 && (
                <View style={styles.section}>
                  <SectionHeader title="Recent" />
                  <ScrollView horizontal showsHorizontalScrollIndicator={false} contentContainerStyle={{ gap: 10 }}>
                    {recentItems.map((f) => (
                      <FeatureCard
                        key={f!.id}
                        icon={f!.icon}
                        title={f!.name}
                        size="small"
                        category={f!.category as any}
                        onPress={() => navigate(f!.route, f!.id)}
                      />
                    ))}
                  </ScrollView>
                </View>
              )}

              {/* ── Weather ── */}
              <View style={styles.section}>
                <SectionHeader title="Weather" />
                <View style={[styles.weatherCard, { backgroundColor: theme.colors.surface, borderColor: theme.colors.border }, theme.shadows.card]}>
                  <LinearGradient
                    colors={[...theme.colors.gradient]}
                    style={styles.weatherGradient}
                    start={{ x: 0, y: 0 }}
                    end={{ x: 1, y: 1 }}
                  >
                    {loading ? (
                      <View style={styles.weatherLoading}>
                        <MaterialCommunityIcons name="weather-partly-cloudy" size={48} color="rgba(255,255,255,0.5)" />
                        <Text style={styles.weatherLoadingText}>Loading…</Text>
                      </View>
                    ) : weather ? (
                      <View style={styles.weatherContent}>
                        <View style={styles.weatherLeft}>
                          <MaterialCommunityIcons
                            name={weatherInfo?.icon as any}
                            size={56}
                            color="rgba(255,255,255,0.9)"
                          />
                          <Text style={styles.weatherCondition}>{weatherInfo?.label}</Text>
                        </View>
                        <View style={styles.weatherRight}>
                          <Text style={styles.weatherTemp}>{temp}°</Text>
                          <Text style={styles.weatherWind}>💨 {wind} km/h</Text>
                          <Text style={styles.weatherLocation}>New York, US</Text>
                        </View>
                      </View>
                    ) : (
                      <View style={styles.weatherLoading}>
                        <MaterialCommunityIcons name="wifi-off" size={36} color="rgba(255,255,255,0.6)" />
                        <Text style={styles.weatherLoadingText}>Weather unavailable</Text>
                      </View>
                    )}
                  </LinearGradient>
                </View>
              </View>

              {/* ── Daily Quote ── */}
              <View style={styles.section}>
                <SectionHeader title="Daily Quote" />
                <View style={[styles.quoteCard, { backgroundColor: theme.colors.surface, borderColor: theme.colors.border }, theme.shadows.card]}>
                  <MaterialCommunityIcons name="format-quote-open" size={28} color={theme.colors.accent} style={{ marginBottom: 4 }} />
                  {loading ? (
                    <View style={{ gap: 8 }}>
                      <View style={[styles.skeleton, { width: '100%', backgroundColor: theme.colors.surfaceSecondary }]} />
                      <View style={[styles.skeleton, { width: '70%', backgroundColor: theme.colors.surfaceSecondary }]} />
                    </View>
                  ) : quote ? (
                    <>
                      <Text style={[styles.quoteText, { color: theme.colors.text, fontFamily: theme.fontFamily.regular }]}>
                        {quote.content}
                      </Text>
                      <Text style={[styles.quoteAuthor, { color: theme.colors.accent, fontFamily: theme.fontFamily.semiBold }]}>
                        — {quote.author}
                      </Text>
                    </>
                  ) : (
                    <Text style={[styles.quoteText, { color: theme.colors.textSecondary }]}>
                      "The only way to do great work is to love what you do."
                    </Text>
                  )}
                </View>
              </View>

              {/* ── Explore All ── */}
              <View style={styles.section}>
                <SectionHeader
                  title="Explore All"
                  action="See all"
                  onAction={() => router.push('/(tabs)/tools' as any)}
                />
                <View style={styles.grid}>
                  {categories.slice(1).map((cat) => (
                    <View key={cat.id} style={styles.gridItem}>
                      <FeatureCard
                        icon={cat.icon}
                        title={cat.label}
                        description={cat.description}
                        category={cat.id as any}
                        onPress={() => router.push(`/(tabs)/${cat.id}` as any)}
                      />
                    </View>
                  ))}
                </View>
              </View>
            </>
          )}

          <View style={{ height: 100 }} />
        </View>
      </ScrollView>
    </View>
  );
}

// ─── Styles ───────────────────────────────────────────────────────────────────

const styles = StyleSheet.create({
  root:   { flex: 1 },
  header: { paddingHorizontal: 20, paddingBottom: 24 },

  headerTop:   { flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16 },
  logoRow:     { flexDirection: 'row', alignItems: 'center', gap: 8 },
  logoIcon:    { width: 32, height: 32, borderRadius: 10, backgroundColor: 'rgba(255,255,255,0.25)', alignItems: 'center', justifyContent: 'center' },
  logoText:    { fontSize: 22, fontWeight: '800', color: '#FFFFFF', letterSpacing: -0.3 },
  settingsBtn: { width: 36, height: 36, borderRadius: 12, backgroundColor: 'rgba(255,255,255,0.18)', alignItems: 'center', justifyContent: 'center' },

  greeting:    { fontSize: 26, fontWeight: '800', color: '#FFFFFF', letterSpacing: -0.3 },
  subGreeting: { fontSize: 14, color: 'rgba(255,255,255,0.7)', marginTop: 2, marginBottom: 16 },

  searchBar: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 10,
    borderRadius: 16,
    paddingHorizontal: 14,
    paddingVertical: Platform.OS === 'ios' ? 12 : 8,
    borderWidth: 1,
    borderColor: 'rgba(255,255,255,0.3)',
  },
  searchInput: { flex: 1, fontSize: 15 },

  body:   { paddingHorizontal: 16, paddingTop: 20 },
  section: { marginBottom: 24 },

  catRow: { flexDirection: 'row', gap: 10, marginBottom: 24 },
  catTile: {
    flex: 1,
    alignItems: 'center',
    paddingVertical: 14,
    borderRadius: 16,
    gap: 6,
    borderWidth: 1,
  },
  catLabel: { fontSize: 11 },

  grid:     { flexDirection: 'row', flexWrap: 'wrap', gap: 12 },
  gridItem: { width: '47%' },

  weatherCard:     { borderRadius: 20, overflow: 'hidden', borderWidth: 1 },
  weatherGradient: { padding: 20, borderRadius: 20 },
  weatherLoading:  { alignItems: 'center', gap: 8, paddingVertical: 12 },
  weatherLoadingText: { color: 'rgba(255,255,255,0.7)', fontSize: 14 },
  weatherContent:  { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between' },
  weatherLeft:     { alignItems: 'center', gap: 4 },
  weatherCondition: { color: 'rgba(255,255,255,0.8)', fontSize: 12 },
  weatherRight:    { alignItems: 'flex-end' },
  weatherTemp:     { fontSize: 56, fontWeight: '800', color: '#FFFFFF', lineHeight: 60 },
  weatherWind:     { color: 'rgba(255,255,255,0.8)', fontSize: 13, marginTop: 4 },
  weatherLocation: { color: 'rgba(255,255,255,0.6)', fontSize: 12, marginTop: 2 },

  quoteCard:   { borderRadius: 20, padding: 20, borderWidth: 1 },
  quoteText:   { fontSize: 16, lineHeight: 26, marginBottom: 12 },
  quoteAuthor: { fontSize: 13 },

  skeleton: { height: 14, borderRadius: 7 },

  emptySearch: { alignItems: 'center', paddingVertical: 48, gap: 8 },
  emptyText:   { fontSize: 15 },
});
